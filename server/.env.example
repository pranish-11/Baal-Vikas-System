# Copy this file to .env and fill in real values.
# NEVER commit .env — it contains secrets.

# Server
PORT=8011
HOST=0.0.0.0

# MongoDB connection string (e.g. MongoDB Atlas)
DATABASE_URL="mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/axion_montessori?retryWrites=true&w=majority"

# CORS — set to your frontend URL in production, e.g. https://your-app.vercel.app
CORS_ORIGIN=http://localhost:5173

# JWT signing secret — use a long random string, e.g. output of: openssl rand -hex 32
JWT_SECRET=replace_with_a_long_random_secret

# Groq API key — get one at https://console.groq.com
GROQ_API_KEY=gsk_replace_with_your_groq_key

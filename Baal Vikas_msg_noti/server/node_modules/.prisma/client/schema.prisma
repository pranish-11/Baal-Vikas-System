  provider = "mongodb"
  url      = "mongodb+srv://pranishbhuju99_db_user:pranish_99x@cluster0.mrypgpc.mongodb.net/axion_montessori?retryWrites=true&w=majority&appName=Cluster0"
}

enum UserRole {
  ADMIN
  TEACHER
  PARENT
}

enum ComplaintStatus {
  OPEN
  IN_PROGRESS
  ESCALATED
  RESOLVED
}

enum ComplaintType {
  BEHAVIOR
  SAFETY
  OTHER
}

enum ComplaintPriority {
  LOW
  MEDIUM
  HIGH
}

enum ChatDirection {
  IN
  OUT
}

model School {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  name          String
  location      String?
  studentsCount Int      @default(0)
  teachersCount Int      @default(0)
  status        String   @default("active")
  principalName String?
  contactEmail  String?
  classrooms    Int?     @default(0)
  phone         String?
  address       String?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  students Student[]
  users    User[]
  fees     Fee[]
}

model User {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  name         String
  email        String   @unique
  passwordHash String?
  role         UserRole
  schoolId     String?  @db.ObjectId
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  school School? @relation(fields: [schoolId], references: [id])

  threadIds String[]        @db.ObjectId
  threads   MessageThread[] @relation(fields: [threadIds], references: [id])

  sentChats MessageChat[]
}

model Student {
  id             String    @id @default(auto()) @map("_id") @db.ObjectId
  fullName       String
  className      String
  behaviorScore  Int       @default(0)
  attendancePct  Int       @default(0)
  avatarInitials String?
  avatarColor    String?
  age            Int?
  parentName     String?
  parentEmail    String?
  enrollmentDate DateTime?
  medicalNotes   String?
  schoolId       String?   @db.ObjectId
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  school School? @relation(fields: [schoolId], references: [id])
  fees   Fee[]

  @@index([schoolId])
}

model MessageThread {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  participantIds String[] @db.ObjectId
  participants   User[]   @relation(fields: [participantIds], references: [id])

  preview   String?
  timeLabel String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  chats MessageChat[]
}

model MessageChat {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  threadId  String   @db.ObjectId
  senderId  String   @db.ObjectId
  text      String
  timeLabel String
  createdAt DateTime @default(now())

  thread MessageThread @relation(fields: [threadId], references: [id])
  sender User          @relation(fields: [senderId], references: [id])

  @@index([threadId, createdAt])
}

model Complaint {
  id            String            @id @default(auto()) @map("_id") @db.ObjectId
  icon          String?
  title         String
  desc          String
  status        ComplaintStatus   @default(OPEN)
  type          ComplaintType     @default(OTHER)
  priority      ComplaintPriority @default(MEDIUM)
  student       String?
  by            String
  filedByUserId String?           @db.ObjectId
  timeLabel     String
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  replies ComplaintReply[]

  @@index([status])
  @@index([filedByUserId])
}

model ComplaintReply {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  complaintId String   @db.ObjectId
  authorId    String   @db.ObjectId
  authorName  String
  authorRole  String
  text        String
  timeLabel   String
  createdAt   DateTime @default(now())

  complaint Complaint @relation(fields: [complaintId], references: [id])

  @@index([complaintId])
}

model Activity {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  icon      String
  title     String
  desc      String
  timeLabel String
  studentId String?  @db.ObjectId
  createdAt DateTime @default(now())

  @@index([studentId])
}

enum FeeStatus {
  PENDING
  PAID
  OVERDUE
  PARTIAL
}

enum FeeTerm {
  MONTHLY
  QUARTERLY
  ANNUAL
  ONE_TIME
}

enum FeePaymentMethod {
  CASH
  BANK_TRANSFER
  CHEQUE
  ONLINE
}

model Fee {
  id            String            @id @default(auto()) @map("_id") @db.ObjectId
  studentId     String            @db.ObjectId
  schoolId      String?           @db.ObjectId
  title         String
  description   String?
  amount        Float
  amountPaid    Float             @default(0)
  term          FeeTerm           @default(MONTHLY)
  status        FeeStatus         @default(PENDING)
  paymentMethod FeePaymentMethod?
  paidBy        String?
  dueDate       DateTime?
  paidAt        DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  student Student @relation(fields: [studentId], references: [id])
  school  School? @relation(fields: [schoolId], references: [id])

  @@index([studentId])
  @@index([status])
  @@index([schoolId])
}

// Stores daily attendance records per student
model AttendanceRecord {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  studentId String   @db.ObjectId
  date      String // YYYY-MM-DD
  status    String // present | absent | late | leave
  note      String?
  markedBy  String?  @db.ObjectId
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studentId, date])
  @@index([date])
  @@index([studentId])
}

// Broadcast notices from admin/teacher to all parents/teachers
model Notice {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  title      String
  body       String
  authorId   String   @db.ObjectId
  authorName String
  authorRole String
  targetRole String   @default("ALL") // ALL | PARENT | TEACHER
  createdAt  DateTime @default(now())

  @@index([createdAt])
}

// Generic JSON blob storage for frontend data that doesn't fit other models
// Each blob has a unique key (e.g. "axion_behaviour_entries", "axion_attendance")
// and stores arbitrary JSON in the `data` field.
model DataBlob {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  key       String   @unique
  data      String // JSON string
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

# Copy this file to .env and fill in the values for your environment.
# NEVER commit .env — it may contain sensitive URLs.

# Backend API base URL
# Local dev: http://localhost:8011/api
# Production: https://your-render-app.onrender.com/api
VITE_API_BASE=http://localhost:8011/api

# Backend WebSocket URL
# Local dev: http://localhost:8011
# Production: https://your-render-app.onrender.com
VITE_SOCKET_URL=http://localhost:8011

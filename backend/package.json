{
  "name": "axion-montessori-backend",
  "version": "1.0.0",
  "description": "Axion Montessori API — Express + Prisma + MongoDB",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "dev:clean": "powershell -ExecutionPolicy Bypass -File scripts/kill-port-8011.ps1 && nodemon src/server.js",
    "start": "node src/server.js",
    "boot:test": "node scripts/boot-test.js",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "db:seed": "node prisma/seed.js",
    "db:seed-users": "node prisma/seed-users.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.98.0",
    "@prisma/client": "^5.16.2",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "nodemon": "^3.1.4",
    "prisma": "^5.16.2"
  },
  "engines": {
    "node": ">=20"
  }
}
